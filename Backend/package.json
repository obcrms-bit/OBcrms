{
  "name": "trust-education-crm-backend",
  "version": "1.0.0",
  "description": "Trust Education CRM ERP - Backend API",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node seeds/seed.js",
    "seed:chat": "node seeds/chatSeed.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --max-warnings 100",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\" \"**/*.json\"",
    "format:check": "prettier --check \"**/*.js\" \"**/*.json\"",
    "clean": "npm run lint:fix && npm run format",
    "quality": "npm run lint && npm run format:check"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.1",
    "helmet": "^7.2.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "redis": "^4.6.8",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3"
  }
}
