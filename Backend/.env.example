# ==================== SERVER ====================
PORT=5000
NODE_ENV=production

# ==================== DATABASE ====================
# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/trust-crm?retryWrites=true&w=majority

# ==================== AUTHENTICATION ====================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars

# ==================== CORS ====================
# Your deployed frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com

# ==================== EMAIL (optional - only needed for invoice emails) ====================
# Use a Gmail account with an App Password (not your real password)
# Enable 2FA and create App Password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
