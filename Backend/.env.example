# ==================== DATABASE ====================
# Production: Use MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# If your password contains special characters like @ or :, URL-encode them first.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/trust-education-crm?retryWrites=true&w=majority

# ==================== SECURITY ====================
# Generate a fresh secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace_with_a_generated_base64_secret

# ==================== SERVER ====================
PORT=5000
NODE_ENV=production

# ==================== CORS & FRONTEND ====================
# Set to your Vercel frontend domain in production
FRONTEND_URL=https://your-frontend-project.vercel.app
# Optional: allow multiple frontend URLs, separated by commas
FRONTEND_URLS=https://your-frontend-project.vercel.app,https://your-preview-project.vercel.app

# ==================== INTERNAL CHAT ====================
# Optional override if websocket traffic is served from a different origin
SOCKET_ORIGIN=http://localhost:3000

# ==================== EMAIL (Optional) ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ==================== REDIS (Optional) ====================
REDIS_URL=redis://localhost:6379

# ==================== SOCKET.IO (Optional) ====================
SOCKET_IO_ENABLED=false

# ==================== FILE UPLOAD ====================
MAX_FILE_SIZE=10485760

# ==================== LOGGING ====================
LOG_LEVEL=info
