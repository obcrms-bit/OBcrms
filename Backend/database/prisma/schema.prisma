generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  trial
  active
  suspended
  archived
}

enum SubscriptionStatus {
  trial
  active
  past_due
  suspended
  cancelled
}

enum BranchType {
  head_office
  campus
  satellite
  partner_desk
}

enum UserStatus {
  invited
  active
  suspended
  locked
}

enum UserType {
  staff
  agent
  partner
  super_admin
  service_account
}

enum AccessScope {
  none
  own
  own_created
  assigned_to_me
  own_branch
  team
  tenant
  head_office_only
}

enum ServiceType {
  consultancy
  test_prep
}

enum EntityType {
  lead
  client
  student
}

enum LeadStatus {
  new
  open
  qualified
  lost
  converted
  archived
}

enum FollowUpStatus {
  pending
  due_today
  overdue
  completed
  cancelled
}

enum StudentStatus {
  active
  inactive
  alumni
  dropped
}

enum ApplicationStatus {
  draft
  in_progress
  submitted
  offered
  enrolled
  rejected
  closed
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  overdue
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  succeeded
  failed
  reversed
  refunded
}

enum CommissionStatus {
  pending
  approved
  paid
  cancelled
  disputed
}

model Tenant {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantCode         String             @unique @map("tenant_code")
  legalName          String             @map("legal_name")
  displayName        String             @map("display_name")
  slug               String             @unique
  status             TenantStatus       @default(trial)
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  settingsJsonb      Json               @default("{}") @map("settings_jsonb")
  brandingJsonb      Json               @default("{}") @map("branding_jsonb")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")

  branches           Branch[]
  users              User[]
  leads              Lead[]
  students           Student[]
  applications       Application[]
  invoices           Invoice[]
  automationRules    AutomationRule[]
  notifications      Notification[]

  @@map("tenants")
}

model Branch {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid @map("tenant_id")
  branchCode      String      @map("branch_code")
  name            String
  branchType      BranchType  @default(campus) @map("branch_type")
  managerUserId   String?     @db.Uuid @map("manager_user_id")
  inheritBranding Boolean     @default(true) @map("inherit_branding")
  brandingJsonb   Json        @default("{}") @map("branding_jsonb")
  settingsJsonb   Json        @default("{}") @map("settings_jsonb")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  users           User[]
  leads           Lead[]
  students        Student[]
  applications    Application[]
  invoices        Invoice[]
  notifications   Notification[]

  @@unique([tenantId, branchCode])
  @@index([tenantId, managerUserId])
  @@map("branches")
}

model User {
  id                String      @id @default(uuid()) @db.Uuid
  tenantId          String      @db.Uuid @map("tenant_id")
  branchId          String?     @db.Uuid @map("branch_id")
  employeeCode      String?     @map("employee_code")
  fullName          String      @map("full_name")
  email             String      @db.Citext
  passwordHash      String      @map("password_hash")
  status            UserStatus  @default(invited)
  userType          UserType    @default(staff) @map("user_type")
  countries         Json        @default("[]")
  managerUserId     String?     @db.Uuid @map("manager_user_id")
  preferencesJsonb  Json        @default("{}") @map("preferences_jsonb")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  branch            Branch?     @relation(fields: [branchId], references: [id])
  userRoles         UserRole[]
  leadsAssigned     Lead[]      @relation("LeadAssignedTo")
  leadsCreated      Lead[]      @relation("LeadCreatedBy")
  followUpsAssigned FollowUp[]  @relation("FollowUpAssignedUser")

  @@unique([tenantId, email])
  @@index([tenantId, branchId, status])
  @@map("users")
}

model Role {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String?         @db.Uuid @map("tenant_id")
  code             String
  name             String
  isSystem         Boolean         @default(false) @map("is_system")
  scopePolicyJsonb Json            @default("{}") @map("scope_policy_jsonb")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  rolePermissions  RolePermission[]
  userRoles        UserRole[]
  dashboardConfigs DashboardConfig[]

  @@index([tenantId, code])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  moduleKey       String           @map("module_key")
  actionKey       String           @map("action_key")
  permissionKey   String           @unique @map("permission_key")
  isSensitive     Boolean          @default(false) @map("is_sensitive")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id               String      @id @default(uuid()) @db.Uuid
  roleId           String      @db.Uuid @map("role_id")
  permissionId     String      @db.Uuid @map("permission_id")
  isAllowed        Boolean     @default(true) @map("is_allowed")
  accessScope      AccessScope @default(own) @map("access_scope")
  fieldPolicyJsonb Json        @default("{}") @map("field_policy_jsonb")

  role             Role        @relation(fields: [roleId], references: [id])
  permission       Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid @map("tenant_id")
  userId          String      @db.Uuid @map("user_id")
  roleId          String      @db.Uuid @map("role_id")
  branchId        String?     @db.Uuid @map("branch_id")
  scopeType       AccessScope @default(own) @map("scope_type")
  scopeRulesJsonb Json        @default("{}") @map("scope_rules_jsonb")
  assignedAt      DateTime    @default(now()) @map("assigned_at")
  deletedAt       DateTime?   @map("deleted_at")

  user            User        @relation(fields: [userId], references: [id])
  role            Role        @relation(fields: [roleId], references: [id])

  @@index([tenantId, userId])
  @@map("user_roles")
}

model LeadStage {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid @map("tenant_id")
  branchId      String?      @db.Uuid @map("branch_id")
  serviceType   ServiceType  @map("service_type")
  countryCode   String?      @map("country_code")
  code          String
  label         String
  stageOrder    Int          @map("stage_order")
  settingsJsonb Json         @default("{}") @map("settings_jsonb")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  leads         Lead[]

  @@index([tenantId, serviceType, countryCode, stageOrder])
  @@map("lead_stages")
}

model Lead {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @db.Uuid @map("tenant_id")
  branchId           String       @db.Uuid @map("branch_id")
  createdBy          String       @db.Uuid @map("created_by")
  assignedTo         String?      @db.Uuid @map("assigned_to")
  leadStageId        String?      @db.Uuid @map("lead_stage_id")
  serviceType        ServiceType  @map("service_type")
  entityType         EntityType   @default(lead) @map("entity_type")
  status             LeadStatus   @default(new)
  fullName           String       @map("full_name")
  email              String?      @db.Citext
  mobile             String?
  preferredCountries Json         @default("[]") @map("preferred_countries")
  leadScore          Int          @default(0) @map("lead_score")
  sourceMetaJsonb    Json         @default("{}") @map("source_meta_jsonb")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  deletedAt          DateTime?    @map("deleted_at")

  tenant             Tenant       @relation(fields: [tenantId], references: [id])
  branch             Branch       @relation(fields: [branchId], references: [id])
  creator            User         @relation("LeadCreatedBy", fields: [createdBy], references: [id])
  assignee           User?        @relation("LeadAssignedTo", fields: [assignedTo], references: [id])
  leadStage          LeadStage?   @relation(fields: [leadStageId], references: [id])
  followUps          FollowUp[]
  students           Student[]

  @@index([tenantId, branchId, status])
  @@map("leads")
}

model FollowUp {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @db.Uuid @map("tenant_id")
  branchId            String         @db.Uuid @map("branch_id")
  leadId              String         @db.Uuid @map("lead_id")
  assignedUserId      String         @db.Uuid @map("assigned_user_id")
  status              FollowUpStatus @default(pending)
  dueAt               DateTime       @map("due_at")
  nextFollowUpAt      DateTime?      @map("next_follow_up_at")
  notes               String
  completionMetaJsonb Json           @default("{}") @map("completion_meta_jsonb")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  lead                Lead           @relation(fields: [leadId], references: [id])
  assignedUser        User           @relation("FollowUpAssignedUser", fields: [assignedUserId], references: [id])

  @@index([tenantId, assignedUserId, status, dueAt])
  @@map("follow_ups")
}

model Student {
  id                   String         @id @default(uuid()) @db.Uuid
  tenantId             String         @db.Uuid @map("tenant_id")
  branchId             String         @db.Uuid @map("branch_id")
  sourceLeadId         String?        @db.Uuid @map("source_lead_id")
  assignedCounsellorId String?        @db.Uuid @map("assigned_counsellor_id")
  serviceType          ServiceType    @map("service_type")
  entityType           EntityType     @default(student) @map("entity_type")
  status               StudentStatus  @default(active)
  studentCode          String         @map("student_code")
  fullName             String         @map("full_name")
  email                String?        @db.Citext
  customSnapshotJsonb  Json           @default("{}") @map("custom_snapshot_jsonb")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  tenant               Tenant         @relation(fields: [tenantId], references: [id])
  branch               Branch         @relation(fields: [branchId], references: [id])
  sourceLead           Lead?          @relation(fields: [sourceLeadId], references: [id])
  applications         Application[]
  invoices             Invoice[]

  @@unique([tenantId, studentCode])
  @@map("students")
}

model University {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid @map("tenant_id")
  name           String
  countryCode    String       @map("country_code")
  metadataJsonb  Json         @default("{}") @map("metadata_jsonb")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  programs       Program[]
  applications   Application[]

  @@map("universities")
}

model Program {
  id                   String       @id @default(uuid()) @db.Uuid
  tenantId             String       @db.Uuid @map("tenant_id")
  universityId         String       @db.Uuid @map("university_id")
  name                 String
  countryCode          String       @map("country_code")
  intakeOptions        Json         @default("[]") @map("intake_options")
  scholarshipInfoJsonb Json         @default("{}") @map("scholarship_info_jsonb")
  metadataJsonb        Json         @default("{}") @map("metadata_jsonb")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  deletedAt            DateTime?    @map("deleted_at")

  university           University   @relation(fields: [universityId], references: [id])
  applications         Application[]

  @@map("programs")
}

model Application {
  id                    String            @id @default(uuid()) @db.Uuid
  tenantId              String            @db.Uuid @map("tenant_id")
  branchId              String            @db.Uuid @map("branch_id")
  studentId             String            @db.Uuid @map("student_id")
  universityId          String            @db.Uuid @map("university_id")
  programId             String            @db.Uuid @map("program_id")
  workflowDefinitionId  String?           @db.Uuid @map("workflow_definition_id")
  status                ApplicationStatus @default(draft)
  timelineSnapshotJsonb Json              @default("{}") @map("timeline_snapshot_jsonb")
  documentStateJsonb    Json              @default("{}") @map("document_state_jsonb")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  branch                Branch            @relation(fields: [branchId], references: [id])
  student               Student           @relation(fields: [studentId], references: [id])
  university            University        @relation(fields: [universityId], references: [id])
  program               Program           @relation(fields: [programId], references: [id])
  invoices              Invoice[]

  @@index([tenantId, branchId, status])
  @@map("applications")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid @map("tenant_id")
  branchId      String        @db.Uuid @map("branch_id")
  studentId     String?       @db.Uuid @map("student_id")
  applicationId String?       @db.Uuid @map("application_id")
  invoiceNumber String        @map("invoice_number")
  status        InvoiceStatus @default(draft)
  totalAmount   Decimal       @db.Decimal(12, 2) @map("total_amount")
  balanceAmount Decimal       @db.Decimal(12, 2) @map("balance_amount")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])
  student       Student?      @relation(fields: [studentId], references: [id])
  application   Application?  @relation(fields: [applicationId], references: [id])
  payments      Payment[]

  @@unique([tenantId, invoiceNumber])
  @@map("invoices")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid @map("tenant_id")
  branchId       String        @db.Uuid @map("branch_id")
  invoiceId      String        @db.Uuid @map("invoice_id")
  status         PaymentStatus @default(pending)
  amount         Decimal       @db.Decimal(12, 2)
  currencyCode   String        @map("currency_code")
  methodMetaJsonb Json         @default("{}") @map("method_meta_jsonb")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  invoice        Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, status])
  @@map("payments")
}

model Commission {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid @map("tenant_id")
  applicationId String?          @db.Uuid @map("application_id")
  invoiceId     String?          @db.Uuid @map("invoice_id")
  status        CommissionStatus @default(pending)
  amount        Decimal          @db.Decimal(12, 2)
  currencyCode  String           @map("currency_code")
  metaJsonb     Json             @default("{}") @map("meta_jsonb")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  @@index([tenantId, status])
  @@map("commissions")
}

model AutomationRule {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid @map("tenant_id")
  branchId       String?     @db.Uuid @map("branch_id")
  moduleKey      String      @map("module_key")
  name           String
  triggerEvent   String      @map("trigger_event")
  conditionsJsonb Json       @default("[]") @map("conditions_jsonb")
  actionsJsonb   Json        @default("[]") @map("actions_jsonb")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  tenant         Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, moduleKey, triggerEvent])
  @@map("automation_rules")
}

model Notification {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @db.Uuid @map("tenant_id")
  branchId         String?     @db.Uuid @map("branch_id")
  userId           String      @db.Uuid @map("user_id")
  notificationType String      @map("notification_type")
  title            String
  message          String
  payloadJsonb     Json        @default("{}") @map("payload_jsonb")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")

  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  branch           Branch?     @relation(fields: [branchId], references: [id])

  @@index([tenantId, userId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String?     @db.Uuid @map("tenant_id")
  branchId         String?     @db.Uuid @map("branch_id")
  actorUserId      String?     @db.Uuid @map("actor_user_id")
  actionKey        String      @map("action_key")
  moduleKey        String      @map("module_key")
  targetEntityType String      @map("target_entity_type")
  targetEntityId   String?     @db.Uuid @map("target_entity_id")
  beforeJsonb      Json        @default("{}") @map("before_jsonb")
  afterJsonb       Json        @default("{}") @map("after_jsonb")
  occurredAt       DateTime    @default(now()) @map("occurred_at")

  @@index([tenantId, moduleKey, occurredAt])
  @@map("audit_logs")
}

model CustomField {
  id                String      @id @default(uuid()) @db.Uuid
  tenantId          String      @db.Uuid @map("tenant_id")
  moduleKey         String      @map("module_key")
  fieldKey          String      @map("field_key")
  label             String
  dataType          String      @map("data_type")
  validationJsonb   Json        @default("{}") @map("validation_jsonb")
  optionsJsonb      Json        @default("[]") @map("options_jsonb")
  defaultValueJsonb Json        @default("null") @map("default_value_jsonb")
  displayOrder      Int         @default(1) @map("display_order")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  values            CustomFieldValue[]

  @@unique([tenantId, moduleKey, fieldKey])
  @@map("custom_fields")
}

model CustomFieldValue {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @db.Uuid @map("tenant_id")
  customFieldId String      @db.Uuid @map("custom_field_id")
  entityType    String      @map("entity_type")
  entityId      String      @db.Uuid @map("entity_id")
  valueText     String?     @map("value_text")
  valueJsonb    Json?       @map("value_jsonb")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  customField   CustomField @relation(fields: [customFieldId], references: [id])

  @@unique([customFieldId, entityType, entityId])
  @@map("custom_field_values")
}

model DynamicForm {
  id                  String      @id @default(uuid()) @db.Uuid
  tenantId            String      @db.Uuid @map("tenant_id")
  branchId            String?     @db.Uuid @map("branch_id")
  formType            String      @map("form_type")
  name                String
  slug                String
  title               String
  moduleKey           String      @map("module_key")
  defaultValuesJsonb  Json        @default("{}") @map("default_values_jsonb")
  submissionRulesJsonb Json       @default("{}") @map("submission_rules_jsonb")
  themeJsonb          Json        @default("{}") @map("theme_jsonb")
  embedMetaJsonb      Json        @default("{}") @map("embed_meta_jsonb")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  deletedAt           DateTime?   @map("deleted_at")

  fields              DynamicFormField[]

  @@unique([tenantId, slug])
  @@map("dynamic_forms")
}

model DynamicFormField {
  id                   String      @id @default(uuid()) @db.Uuid
  tenantId             String      @db.Uuid @map("tenant_id")
  formId               String      @db.Uuid @map("form_id")
  fieldKey             String      @map("field_key")
  label                String
  fieldType            String      @map("field_type")
  sourceType           String      @default("core") @map("source_type")
  optionsJsonb         Json        @default("[]") @map("options_jsonb")
  validationJsonb      Json        @default("{}") @map("validation_jsonb")
  visibilityRulesJsonb Json        @default("{}") @map("visibility_rules_jsonb")
  displayOrder         Int         @default(1) @map("display_order")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  deletedAt            DateTime?   @map("deleted_at")

  form                 DynamicForm @relation(fields: [formId], references: [id])

  @@unique([formId, fieldKey])
  @@map("dynamic_form_fields")
}

model WorkflowDefinition {
  id                   String      @id @default(uuid()) @db.Uuid
  tenantId             String      @db.Uuid @map("tenant_id")
  moduleKey            String      @map("module_key")
  scopeCountryCode     String?     @map("scope_country_code")
  name                 String
  versionNo            Int         @default(1) @map("version_no")
  stagesJsonb          Json        @default("[]") @map("stages_jsonb")
  transitionsJsonb     Json        @default("[]") @map("transitions_jsonb")
  slaRulesJsonb        Json        @default("{}") @map("sla_rules_jsonb")
  automationHooksJsonb Json        @default("{}") @map("automation_hooks_jsonb")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  deletedAt            DateTime?   @map("deleted_at")

  @@index([tenantId, moduleKey, scopeCountryCode])
  @@map("workflow_definitions")
}

model DashboardConfig {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @db.Uuid @map("tenant_id")
  branchId         String?     @db.Uuid @map("branch_id")
  roleId           String?     @db.Uuid @map("role_id")
  moduleKey        String      @map("module_key")
  name             String
  layoutJsonb      Json        @default("{}") @map("layout_jsonb")
  widgetRulesJsonb Json        @default("{}") @map("widget_rules_jsonb")
  visibilityJsonb  Json        @default("{}") @map("visibility_jsonb")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")

  role             Role?       @relation(fields: [roleId], references: [id])

  @@index([tenantId, branchId, roleId, moduleKey])
  @@map("dashboard_configs")
}

model IntegrationSetting {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid @map("tenant_id")
  branchId        String?     @db.Uuid @map("branch_id")
  integrationType String      @map("integration_type")
  providerName    String      @map("provider_name")
  name            String
  isEnabled       Boolean     @default(true) @map("is_enabled")
  configJsonb     Json        @default("{}") @map("config_jsonb")
  secretRefJsonb  Json        @default("{}") @map("secret_ref_jsonb")
  healthJsonb     Json        @default("{}") @map("health_jsonb")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  @@index([tenantId, branchId, integrationType, providerName])
  @@map("integration_settings")
}
