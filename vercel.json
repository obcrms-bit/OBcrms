{
    "version": 2,
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "installCommand": "npm ci",
    "framework": "nextjs",
    "env": {
        "NEXT_PUBLIC_API_URL": "@api_url",
        "NEXT_PUBLIC_APP_NAME": "@app_name"
    },
    "rewrites": [
        {
            "source": "/:path*",
            "destination": "/:path*"
        }
    ]
}