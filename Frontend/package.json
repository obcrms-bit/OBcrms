  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx --max-warnings 10",
    "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"app/**/*.{ts,tsx,jsx}\" \"src/**/*.{js,jsx,ts,tsx}\" \"components/**/*.{ts,tsx,jsx}\" \"context/**/*.{ts,tsx,jsx}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,jsx}\" \"src/**/*.{js,jsx,ts,tsx}\" \"components/**/*.{ts,tsx,jsx}\" \"context/**/*.{ts,tsx,jsx}\"",
    "clean": "npm run lint:fix && npm run format",
    "quality": "npm run lint && npm run format:check"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.3"
  }
}